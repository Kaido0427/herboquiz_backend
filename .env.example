APP_NAME=HerboQuiz
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Heure du Benin : toutes les dates affichees en dependent.
APP_TIMEZONE=Africa/Porto-Novo
APP_URL=https://herboquiz.novafriq.africa

LOG_CHANNEL=stack
LOG_LEVEL=warning

# PostgreSQL en local comme en production : le meme moteur des deux cotes evite
# les bugs qui n'apparaissent qu'en prod.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=herboquiz
DB_USERNAME=herboquiz_user
DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Duree d'une session, en minutes. Genereuse a dessein : etre deconnecte au
# milieu d'une manche, avec le groupe qui attend, serait le pire moment.
SESSION_MINUTES=720
